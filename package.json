{
  "name": "@tetherto/miningos-tpl-wrk-thing",
  "version": "1.0.0",
  "description": "MiningOS Template Worker Thing",
  "main": "worker.js",
  "keywords": [
    "tether"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetherto/miningos-tpl-wrk-thing.git"
  },
  "homepage": "https://github.com/tetherto/miningos-tpl-wrk-thing#readme",
  "bugs": {
    "url": "https://github.com/tetherto/miningos-tpl-wrk-thing/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "worker.js",
    "workers/",
    "tests/"
  ],
  "type": "commonjs",
  "scripts": {
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "npm run lint && npm run test:unit && npm run test:integration",
    "test:unit": "NODE_ENV=test brittle tests/unit/*.js",
    "test:integration": "npm run test:integration:wrk && npm run test:integration:stats",
    "test:integration:wrk": "cd tests/integration && NODE_ENV=test brittle miner-wrk.js",
    "test:integration:stats": "cd tests/integration && NODE_ENV=test brittle miner-stats.js",
    "test:device": "NODE_ENV=test brittle tests/device.test.js",
    "test:coverage": "brittle --coverage tests/{,**/}*.test.js",
    "openrpc:generate": "node scripts/generate-openrpc.js",
    "openrpc:validate": "node scripts/validate-openrpc.js"
  },
  "dependencies": {
    "@bitfinex/bfx-svc-boot-js": "1.2.0",
    "@bitfinex/lib-js-util-promise": "git+https://github.com/bitfinexcom/lib-js-util-promise.git",
    "@bitfinex/bfx-facs-interval": "git+https://github.com/bitfinexcom/bfx-facs-interval.git",
    "@bitfinex/bfx-facs-scheduler": "git+https://github.com/bitfinexcom/bfx-facs-scheduler.git",
    "@bitfinex/lib-js-util-base": "git+https://github.com/bitfinexcom/lib-js-util-base.git",
    "@tetherto/miningos-lib-stats": "git+https://github.com/tetherto/miningos-lib-stats.git#v1.0.0",
    "@tetherto/svc-facs-miningos-thg-write-calls": "git+https://github.com/tetherto/svc-facs-miningos-thg-write-calls.git#v1.0.0",
    "@tetherto/tether-wrk-base": "git+https://github.com/tetherto/tether-wrk-base.git#v1.0.0",
    "async": "3.2.6",
    "debug": "4.4.1",
    "mingo": "6.5.6",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@open-rpc/schema-utils-js": "2.2.1",
    "brittle": "3.16.3",
    "proxyquire": "2.1.3",
    "standard": "17.1.2",
    "tether-svc-test-helper": "git+https://github.com/tetherto/tether-svc-test-helper.git",
    "ts-json-schema-generator": "2.9.0",
    "typescript": "5.9.3",
    "yargs": "17.7.2"
  }
}
